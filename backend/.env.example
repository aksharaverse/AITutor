# Postgres direct connection string from Supabase (Settings → Database).
# The API connects as the service role and bypasses RLS; RLS policies exist
# only as defense-in-depth for any client-side reads.
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# Supabase → Settings → API → JWT Secret (used to verify user access tokens, HS256)
SUPABASE_JWT_SECRET=your-jwt-secret

# Optional: enables DELETE /v1/me to also remove the auth.users record
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# LLM providers
DEEPSEEK_API_KEY=sk-...
GEMINI_API_KEY=AI...

# Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# App
FRONTEND_URL=http://localhost:8081
FREE_DAILY_LIMIT=10
SENTRY_DSN=
